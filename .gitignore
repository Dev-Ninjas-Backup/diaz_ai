# Environment files
.env                 # sensitive environment variables
.venv/             # local Python virtual environment
uv.lock              # pip-compile lock file

# Python cache and compiled files
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Logs
logs/
*.log

# IDE and editor settings
.idea/

# Notebooks
notebook/
.ipynb_checkpoints/

# Test cache
.pytest_cache/

# Docker
*.tar               # built Docker images (optional)
docker-compose.override.yml  # local overrides

# Miscellaneous files
ab.json
test.py
chat.html
.DS_Store

# Qdrant storage (don't push local data)
qdrant_storage/

# Celery beat schedule (optional, keeps your local schedule file out of git)
celerybeat-schedule


.venv
